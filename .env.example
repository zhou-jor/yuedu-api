NODE_ENV=development
PORT=3000

# MongoDB
MONGO_URI=mongodb://mongo:27017/yuedu

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=2h
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# SMS (placeholder)
SMS_API_KEY=
SMS_API_SECRET=

# App
APP_NAME=悦读
API_PREFIX=/api
CORS_ORIGIN=*
